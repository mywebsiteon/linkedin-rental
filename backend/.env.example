# Eagle Web Commerce - Environment Variables
# Copy this to .env and fill in your values

# Server
PORT=3000
NODE_ENV=development

# Security
JWT_SECRET=eagleweb-secret-key-change-in-production

# CORS (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ==========================================
# PESAPAL CONFIGURATION
# Get your keys from: https://developer.pesapal.com/
# ==========================================
PESAPAL_KEY=your-pesapal-consumer-key
PESAPAL_SECRET=your-pesapal-consumer-secret
PESAPAL_URL=https://demo.pesapal.com
PESAPAL_CALLBACK=https://eaglewebcommerce.com/payment-callback

# ==========================================
# COINBASE COMMERCE CONFIGURATION
# Get your keys from: https://commerce.coinbase.com/
# ==========================================
COINBASE_KEY=your-coinbase-api-key
COINBASE_WEBHOOK_SECRET=your-coinbase-webhook-secret
COINBASE_CALLBACK=https://eaglewebcommerce.com/coinbase-callback